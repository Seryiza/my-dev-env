#!/usr/bin/env bash
set -euo pipefail

direction=${1:-}
workspace_fallback=

case "$direction" in
  h|left)
    sway_direction=left
    emacs_direction=left
    workspace_fallback=prev
    ;;
  j|down)
    sway_direction=down
    emacs_direction=below
    ;;
  k|up)
    sway_direction=up
    emacs_direction=above
    ;;
  l|right)
    sway_direction=right
    emacs_direction=right
    workspace_fallback=next
    ;;
  *)
    printf 'usage: %s {h|j|k|l|left|down|up|right}\n' "$0" >&2
    exit 64
    ;;
esac

focused_node_id() {
  swaymsg -t get_tree \
    | jq -r 'first(.. | objects | select(.focused == true) | .id) // empty'
}

focused_app_is_emacs() {
  swaymsg -t get_tree \
    | jq -e '
      ..
      | objects
      | select(.focused == true)
      | (
          (.app_id? == "emacs")
          or ((.window_properties?.class? // "") | test("^[Ee]macs$"))
          or ((.window_properties?.instance? // "") | test("^[Ee]macs$"))
        )
    ' >/dev/null
}

before_focus_id=
if [[ -n "$workspace_fallback" ]]; then
  before_focus_id=$(focused_node_id)
fi

if focused_app_is_emacs; then
  if result=$(emacsclient --eval "(sz/sway-nav '$emacs_direction)" 2>/dev/null); then
    result=${result//[[:space:]]/}
    if [[ "$result" == "t" ]]; then
      exit 0
    fi
  fi
fi

if ! swaymsg "focus $sway_direction" >/dev/null; then
  if [[ -n "$workspace_fallback" ]]; then
    exec swaymsg "workspace $workspace_fallback" >/dev/null
  fi
  exit 1
fi

if [[ -n "$workspace_fallback" ]]; then
  after_focus_id=$(focused_node_id)
  if [[ -n "$before_focus_id" && "$before_focus_id" == "$after_focus_id" ]]; then
    exec swaymsg "workspace $workspace_fallback" >/dev/null
  fi
fi
