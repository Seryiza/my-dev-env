#!/usr/bin/env bash
set -euo pipefail

focused_app_is_emacs() {
  swaymsg -t get_tree \
    | jq -e '
      ..
      | objects
      | select(.focused == true)
      | (
          (.app_id? == "emacs")
          or ((.window_properties?.class? // "") | test("^[Ee]macs$"))
          or ((.window_properties?.instance? // "") | test("^[Ee]macs$"))
        )
    ' >/dev/null
}

if focused_app_is_emacs; then
  if emacsclient --eval "(sz/sway-new-tab)" >/dev/null 2>&1; then
    exit 0
  fi
fi

exec emacsclient -c >/dev/null
